# Copy to .env and fill in. .env is git-ignored.

# Local Postgres (matches Homebrew postgresql@16 install on this machine)
DATABASE_URL=postgresql://srishtia@localhost:5432/migration_estimator

# JWT — use a strong random string in any non-local env
JWT_SECRET_KEY=dev-secret-change-in-production
JWT_EXPIRE_MINUTES=1440

# Seed user (created on first prisma migrate if absent)
SEED_USER_EMAIL=admin@example.com
SEED_USER_PASSWORD=ChangeMe123!
SEED_USER_DISPLAY_NAME=Admin

# Workfront credentials (copy from Render if you want parity with prod data)
WF_API_URL=
WF_API_KEY=
